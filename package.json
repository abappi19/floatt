{
  "name": "floatt",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@floatt/web",
    "dev:desktop": "pnpm --filter @floatt/desktop tauri dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types"
  },
  "dependencies": {
    "@floatt/app": "workspace:*"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
